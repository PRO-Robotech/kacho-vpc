{
  "info": {
    "_postman_id": "71584bc9-1aff-4826-9c1c-b0c8a15e2efb",
    "name": "kacho-vpc / newman2 / private-endpoint",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (!pm.environment.get('runId') || pm.environment.get('runId') === '') {",
          "  // runId формат: только [a-z0-9], без точки — чтобы проходить name regex.",
          "  const t = Date.now().toString(36);",
          "  const r = Math.floor(Math.random() * 1e9).toString(36);",
          "  pm.environment.set('runId', (t + r).replace(/[^a-z0-9]/g, '').slice(-10));",
          "}",
          "pm.environment.set('_suiteFolderId', pm.environment.get('existingFolderId'));",
          "pm.environment.set('_suiteFolderCrossId', pm.environment.get('existingFolderCrossId'));"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "PE-CR-VAL-FOLDER-REQUIRED — Create без folder → InvalidArgument",
      "description": "class:VAL | priority:P0",
      "item": [
        {
          "name": "create-no-folder",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/vpc/v1/endpoints",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "vpc",
                "v1",
                "endpoints"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\"name\": \"pe-nf-{{runId}}\"}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 400', () => pm.expect(pm.response.code).to.eql(400));",
                  "pm.test('grpc code 3 (INVALID_ARGUMENT)', () => {",
                  "  const j = pm.response.json();",
                  "  pm.expect(j.code, JSON.stringify(j)).to.eql(3);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "PE-CR-NEG-NETWORK-NF — Create в несуществующую network → async NotFound",
      "description": "class:NEG | priority:P0",
      "item": [
        {
          "name": "create",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/vpc/v1/endpoints",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "vpc",
                "v1",
                "endpoints"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\"folderId\": \"{{_suiteFolderId}}\", \"name\": \"pe-nn-{{runId}}\", \"networkId\": \"{{garbageVpcId}}\", \"objectStorage\": {}}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', () => pm.expect(pm.response.code).to.eql(200));",
                  "try {",
                  "  const j = pm.response.json();",
                  "  const v = (j.id);",
                  "  if (v !== undefined && v !== null) pm.environment.set('opId', String(v));",
                  "} catch (e) {}"
                ]
              }
            }
          ]
        },
        {
          "name": "poll-op",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/operations/{{opId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "operations",
                "{{opId}}"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('poll status 200', () => pm.expect(pm.response.code).to.eql(200));",
                  "const j = pm.response.json();",
                  "pm.test('operation done', () => pm.expect(j.done, JSON.stringify(j)).to.eql(true));",
                  "// сохранить error/response для последующих ассертов",
                  "if (j.error) pm.environment.set('lastOpError', JSON.stringify(j.error));",
                  "else pm.environment.unset('lastOpError');",
                  "if (j.response) pm.environment.set('lastOpResponse', JSON.stringify(j.response));"
                ]
              }
            }
          ]
        },
        {
          "name": "assert-nf",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/operations/{{opId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "operations",
                "{{opId}}"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('error code 5', () => pm.expect(pm.response.json().error && pm.response.json().error.code).to.eql(5));"
                ]
              }
            }
          ]
        }
      ]
    },
