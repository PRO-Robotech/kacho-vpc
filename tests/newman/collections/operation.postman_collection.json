            ],
            "url": {
              "raw": "{{baseUrl}}/operations/{{garbageId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "operations",
                "{{garbageId}}"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 400', () => pm.expect(pm.response.code).to.eql(400));",
                  "pm.test('grpc code 3 (INVALID_ARGUMENT)', () => {",
                  "  const j = pm.response.json();",
                  "  pm.expect(j.code, JSON.stringify(j)).to.eql(3);",
                  "});",
                  "pm.test('mentions invalid operation id', () => pm.expect(pm.response.json().message).to.include('invalid operation id'));"
                ]
              }
            }
          ]
        }
      ]
