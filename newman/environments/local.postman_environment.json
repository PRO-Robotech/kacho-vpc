    },
    {
      "key": "requiresCloudMutationOK",
      "value": "true",
      "type": "default",
      "enabled": true,
      "description": "Local Kachō stand allows tests to create/delete Cloud and Organization. Set 'false' for environments where these mutations are not allowed (e.g. real cloud provider with quotas)."
    },
    {
      "key": "existingOrgId",
      "value": "",
      "type": "default",
      "enabled": true,
      "description": "Pre-allocated organization id (used together with existingFolderId/CloudId). Empty for local — preflight creates Org/Cloud/Folder."
    },
    {
      "key": "existingCloudId",
      "value": "",
