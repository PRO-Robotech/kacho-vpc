      "key": "existingFolderId",
      "value": "",
      "type": "default",
      "enabled": true,
      "description": "Pre-allocated folder id. Set in yc env to disable preflight Org/Cloud/Folder creation; empty in local — preflight creates a fresh suite folder per run."
    },
    {
      "key": "_suiteOrgId",
      "value": "",
