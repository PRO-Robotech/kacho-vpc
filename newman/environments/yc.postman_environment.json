{
  "id": "kacho-yc-env",
  "name": "kacho-yc",
  "values": [
    {
      "key": "backendKind",
      "value": "yc",
      "type": "default",
      "enabled": true
    },
    {
      "key": "baseUrlRm",
      "value": "https://resource-manager.api.cloud.yandex.net",
      "type": "default",
      "enabled": true
    },
    {
      "key": "baseUrlVpc",
      "value": "https://vpc.api.cloud.yandex.net",
      "type": "default",
      "enabled": true
    },
    {
      "key": "baseUrlOp",
      "value": "https://operation.api.cloud.yandex.net",
      "type": "default",
      "enabled": true
    },
    {
      "key": "authHeader",
      "value": "Bearer {{ycToken}}",
      "type": "default",
      "enabled": true
    },
    {
      "key": "ycToken",
      "value": "",
      "type": "secret",
      "enabled": true,
      "description": "Populated automatically by scripts/run.sh when --env yc."
    },
    {
      "key": "requiresCloudMutationOK",
      "value": "false",
      "type": "default",
      "enabled": true,
      "description": "Real cloud provider has quotas + 7-day soft-delete on Cloud/Org — tests must not mutate them. Folders that need Cloud/Org get skipped."
    },
    {
      "key": "existingOrgId",
      "value": "",
      "type": "default",
      "enabled": true,
      "description": "Pre-allocated organization id (optional — leave empty if not needed for VPC suite). 99-teardown skips Org cleanup when existingFolderId is set, so this is only consumed by cases that touch Org directly (none in current Network domain)."
    },
    {
      "key": "existingCloudId",
      "value": "b1g4f0nmru7ee55mu18h",
      "type": "default",
      "enabled": true,
      "description": "Pre-allocated cloud id paired with existingFolderId."
    },
    {
      "key": "existingFolderId",
      "value": "b1gfcs0biit7p23meig5",
      "type": "default",
      "enabled": true,
      "description": "Pre-allocated folder id. Setting this disables 00-preflight Org/Cloud/Folder creation and 99-teardown deletion — the suite reuses this folder. Inside there is an auto-created default Network (enppo47kc0pbqp7pkl21) that tests must NOT touch — they only delete their own qa-{runId}-* resources."
    },
    {
      "key": "_suiteOrgId",
      "value": "",
      "type": "default",
      "enabled": true
    },
    {
      "key": "_suiteCloudId",
      "value": "",
      "type": "default",
      "enabled": true
    },
    {
      "key": "_suiteFolderId",
      "value": "",
      "type": "default",
      "enabled": true
    },
    {
      "key": "existingNetworkId",
      "value": "",
      "type": "default",
      "enabled": true,
      "description": "Default auto-created VPC Network in test cloud — переиспользуется как _suiteNetworkId для тестов которые требуют существующую сеть (Address.internal, Subnet.list, etc)."
    },
    {
      "key": "existingSubnetId",
      "value": "",
      "type": "default",
      "enabled": true,
      "description": "Default auto-created Subnet (ru-central1-a) внутри existingNetworkId — переиспользуется как _suiteSubnetId для Address.internal тестов."
    },
    {
      "key": "_suiteNetworkId",
      "value": "",
      "type": "default",
      "enabled": true
    },
    {
      "key": "_suiteSubnetId",
      "value": "",
      "type": "default",
      "enabled": true
    },
    {
      "key": "_mutatingGapMs",
      "value": "0",
      "type": "default",
      "enabled": true,
      "description": "Min gap between consecutive POST/PATCH/DELETE in YC. Низкое значение + retry-on-429 даёт fast prогон. Если упирается в throttle, retry-loop делает exponential backoff."
    },
    {
